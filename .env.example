# Weights & Biases — https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key_here

# (Opzionale) HuggingFace — serve solo per modelli gated
# HF_TOKEN=your_huggingface_token_here

# (Opzionale) Override del progetto wandb (default: grpo-strict-generation)
# WANDB_PROJECT=grpo-strict-generation

# (Opzionale) Disabilita wandb per test locali senza login
# WANDB_MODE=disabled
